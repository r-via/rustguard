        let mut w = ReplayWindow::new();
        // Send 0, 2, 1, 4, 3 — all should be accepted.
        assert!(w.check_and_update(0));
        assert!(w.check_and_update(2));
        assert!(w.check_and_update(1));
        assert!(w.check_and_update(4));
        assert!(w.check_and_update(3));
