    let config = match Config::from_file(&config_path) {
        Ok(c) => c,
        Err(e) => {
            eprintln!("failed to read config: {e}");
            process::exit(1);
        }
    };

    println!("rustguard starting...");
    if let Err(e) = rustguard_daemon::tunnel::run(config) {
        eprintln!("tunnel error: {e}");
        process::exit(1);
    }
}

