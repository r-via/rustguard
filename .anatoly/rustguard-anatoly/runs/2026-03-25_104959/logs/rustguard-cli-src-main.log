use std::path::PathBuf;
use std::process;

use rustguard_daemon::config::Config;

fn main() {
    let args: Vec<String> = std::env::args().collect();

    match args.get(1).map(|s| s.as_str()) {
        Some("up") => cmd_up(&args[2..]),
        Some("serve") => cmd_serve(&args[2..]),
        Some("join") => cmd_join(&args[2..]),
