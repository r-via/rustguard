                                eprintln!("failed to send response: {e}");
                            } else {
                                println!(
                                    "handshake complete with {} (they initiated)",
                                    base64_key(peer_pubkey.as_bytes()),
                                );
                            }
                        }
                    }
                }

                MSG_RESPONSE if n >= RESPONSE_SIZE => {
                    let msg =
                        Response::from_bytes(buf[..RESPONSE_SIZE].try_into().unwrap());
