pub fn recv_batch(sock: &UdpSocket, batch: &mut RecvBatch) -> io::Result<usize> {
    match sock.recv_from(&mut batch.bufs[0]) {
        Ok((n, addr)) => {
            batch.lens[0] = n;
            batch.addrs[0] = Some(addr);
            batch.count = 1;
            Ok(1)
        }
        Err(ref e) if e.kind() == io::ErrorKind::WouldBlock => {
            batch.count = 0;
            Ok(0)
        }
        Err(e) => Err(e),
    }
