#[cfg(target_os = "linux")]
pub fn send_packet(sock: &UdpSocket, buf: &[u8], addr: SocketAddr) -> io::Result<usize> {
    sock.send_to(buf, addr)
}

/// macOS fallback: receive one packet at a time.
