    pub fn new(tun_fd: i32) -> io::Result<Self> {
        let ring = IoUring::new(RING_ENTRIES)?;
        let mut bufs = BufferPool::new();

        // Register fixed buffers.
        let iovecs = bufs.iovecs();
        unsafe {
            ring.submitter().register_buffers(&iovecs)?;
