    }

    /// Non-blocking: submit pending SQEs and harvest any available completions.
    pub fn poll(&mut self) -> io::Result<Vec<Completion>> {
        self.ring.submit()?;

        let mut completions = Vec::new();
        let cq = self.ring.completion();
