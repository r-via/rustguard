                        ct_buf[0..4].copy_from_slice(&MSG_TRANSPORT.to_le_bytes());
                        ct_buf[4..8].copy_from_slice(&their_index.to_le_bytes());
                        ct_buf[8..16].copy_from_slice(&counter.to_le_bytes());
