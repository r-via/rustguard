                        None => { uring.bufs.free(comp.buf_idx); continue; }
                    };
                    drop(peers);

                    let mut ps = peer.state.lock().unwrap();
                    let (endpoint, their_index) = match (&ps.endpoint, &ps.session) {
                        (Some(ep), Some(s)) => (*ep, s.their_index),
                        _ => { uring.bufs.free(comp.buf_idx); continue; }
                    };

