            let mut pkt_buf = [0u8; 1500];
            let mut ct_buf = [0u8; 1500 + AEAD_TAG_LEN + TRANSPORT_HEADER_SIZE];
            while running_out.load(Ordering::Relaxed) {
                // Read from multi-queue TUN if available, else single TUN.
