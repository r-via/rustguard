AllowedIPs = 10.0.0.2/32, fd00::/64
"#,
        )
        .unwrap();
        assert_eq!(config.peers[0].allowed_ips.len(), 2);
        assert!(config.peers[0].allowed_ips[1].addr.is_ipv6());
    }
